              "children": [
                {
                  "type": "frame",
                  "id": "xmIAX",
                  "name": "Headline Block",
                  "layout": "vertical",
                  "gap": 6,
                  "alignItems": "center",
                  "children": [
                    {
                      "type": "text",
                      "id": "zFUNq",
                      "name": "h1line1",
                      "fill": "$text-tertiary",
                      "content": "The next-gen approach",
                      "textAlign": "center",
                      "fontFamily": "Inter",
                      "fontSize": 20,
                      "fontWeight": "500",
                      "letterSpacing": 1
                    },
                    {
                      "type": "text",
                      "id": "ImmPl",
                      "name": "h1line2",
                      "fill": "$text-primary",
                      "content": "to building software with LLMs",
                      "textAlign": "center",
                      "fontFamily": "Inter",
                      "fontSize": 50,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "a7dQg",
                      "name": "tagline",
                      "fill": "$accent",
                      "content": "You define the what. LLMs generate the how. hlv validates the proof.",
                      "textAlign": "center",
                      "fontFamily": "Inter",
                      "fontSize": 20,
                      "fontWeight": "500"
                    }
                  ]
                },
                {
                  "type": "text",
                  "id": "1bGdJ",
                  "name": "subhead",
                  "fill": "$text-secondary",
                  "textGrowth": "fixed-width",
                  "width": 800,
                  "content": "Specs define the rules. LLMs generate the code. A Rust binary called hlv validates every step — because prompts are not guarantees.",
